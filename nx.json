{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default", "!{projectRoot}/eslint.config.mjs"],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "@angular/build:application": { "cache": true, "dependsOn": ["^build"], "inputs": ["production","^production"] },
    "@nx/eslint:lint": { "cache": true, "inputs": ["default","^default","{workspaceRoot}/eslint.config.mjs"] },
    "@angular/build:unit-test": { "cache": true, "inputs": ["default","^production"] }
  },
  "plugins": [
    { "plugin": "@nx/eslint/plugin", "options": { "targetName": "lint" } }
  ],
  "generators": {
    "@nx/angular:application": { "linter": "eslint", "style": "css", "unitTestRunner": "vitest-angular" },
    "@nx/angular:component": { "style": "css" }
  }
}
